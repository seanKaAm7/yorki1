  preDrawLines:
  - speakerName:
    emotion: neutral
    text: "오, 새로 자리 잡았네."
    shake: 0
  - speakerName:
    emotion: neutral
    text: "여기서 한 번 그려보려고?"
    shake: 0
  - speakerName:
    emotion: neutral
    text: "긴장하지 말고, 편하게 그려."
    shake: 0
  - speakerName:
    emotion: gesture
    text: "허허, 나도 옛날엔 그랬지."
    shake: 0
  - speakerName:
    emotion: gesture
    text: "이 자리 좋아. 사람도 많이 와."
    shake: 0
  - speakerName:
    emotion: neutral
    text: "오늘은 시간 많으니까 천천히 해도 돼."
    shake: 0
  - speakerName:
    emotion: happy
    text: "자, 시작해봐."
    shake: 0
  goodResultLines:
  - speakerName:
    emotion: surprised
    text: "오, 잘 그렸네!"
    shake: 1
  - speakerName:
    emotion: happy
    text: "신입치고 손이 좋아."
    shake: 0
  - speakerName:
    emotion: happy
    text: "고마워, 잘 받았네."
    shake: 0
  - speakerName:
    emotion: gesture
    text: "다음에 또 들를게."
    shake: 0
  badResultLines:
  - speakerName:
    emotion: neutral
    text: "허허..."
    shake: 0
  - speakerName:
    emotion: neutral
    text: "괜찮아, 처음엔 다 그래."
    shake: 0
  - speakerName:
    emotion: neutral
    text: "다음에 더 잘 그리면 돼."
    shake: 0
  - speakerName:
    emotion: happy
    text: "수고했어, 정말."
    shake: 0
