  preDrawLines:
  - emotion: neutral
    text: "여기 앉으면 되는 거죠?"
    shake: 0
  - emotion: neutral
    text: "사람들이 여기 그림 잘 그린다길래요."
    shake: 0
  - emotion: thinking
    text: "근데 너무 예쁘게만 그리진 말고요."
    shake: 0
  - emotion: gesture
    text: "그냥, 딱 저처럼 보이게."
    shake: 0
  - emotion: neutral
    text: "가능하죠?"
    shake: 0
  goodResultLines:
  - emotion: surprised
    text: "오."
    shake: 1
  - emotion: neutral
    text: "생각보다 훨씬 괜찮네요."
    shake: 0
  - emotion: happy
    text: "나쁘지 않아요. 진짜로."
    shake: 0
  - emotion: gesture
    text: "다음에도 여기 있으면 또 올게요."
    shake: 0
  badResultLines:
  - emotion: neutral
    text: "음..."
    shake: 0
  - emotion: thinking
    text: "이건 저보단 다른 사람 같은데요."
    shake: 0
  - emotion: neutral
    text: "그래도 열심히 그린 건 알겠어요."
    shake: 0
  - emotion: gesture
    text: "다음엔 조금만 더 차분히 봐주세요."
    shake: 0
